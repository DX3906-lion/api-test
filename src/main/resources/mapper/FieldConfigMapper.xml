<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.apitest.repository.FieldConfigMapper">
    <resultMap id="BaseMap" type="com.example.apitest.entity.FieldConfig">
        <id column="id" property="id"/>
        <result column="draft_id" property="draftId"/>
        <result column="step_id" property="stepId"/>
        <result column="field_path" property="fieldPath"/>
        <result column="config_type" property="configType"/>
        <result column="param_mode" property="paramMode"/>
        <result column="variable_name" property="variableName"/>
        <result column="variable_label" property="variableLabel"/>
        <result column="remark" property="remark"/>
    </resultMap>
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        insert into field_config(draft_id,step_id,field_path,config_type,param_mode,variable_name,variable_label,remark,deleted)
        values(#{draftId},#{stepId},#{fieldPath},#{configType},#{paramMode},#{variableName},#{variableLabel},#{remark},0)
    </insert>
    <update id="updateById">
        update field_config set field_path=#{fieldPath},config_type=#{configType},param_mode=#{paramMode},variable_name=#{variableName},variable_label=#{variableLabel},remark=#{remark}
        where id=#{id} and deleted=0
    </update>
    <select id="selectById" resultMap="BaseMap">select * from field_config where id=#{id}</select>
    <select id="selectByStepId" resultMap="BaseMap">select * from field_config where step_id=#{stepId} and deleted=0</select>
    <update id="deleteByStepId">update field_config set deleted=1 where step_id=#{stepId}</update>
    <update id="logicalDeleteById">update field_config set deleted=1 where id=#{id}</update>
</mapper>
